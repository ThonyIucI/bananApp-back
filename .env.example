# App
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase local (recomendado):
#   DB_HOST=localhost  DB_PORT=54322  DB_NAME=postgres
#
# Docker Postgres (alternativo):
#   DB_HOST=db  DB_PORT=5432  DB_NAME=cultivapp_dev
DB_HOST=localhost
DB_PORT=54322
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

#___ Google Geminy__________________________________________
GEMINI_API_KEY=CHANGE_ME

# to seed super admin
SUPERADMIN_EMAIL = "alguien@gmail.com"
SUPERADMIN_PASSWORD = "password"
# ── Redis ─────────────────────────────────────────────────────────────────────
# Supabase local expone Redis en 6379; Docker en 6380
REDIS_URL=redis://localhost:6379

# ── Google Verification ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID='GOOGLE_CLIENT_ID'
GOOGLE_CLIENT_SECRET='GOOGLE_CLIENT_SECRET'
GOOGLE_CALLBACK_URL='GOOGLE_CALLBACK_URL'